# Snowflake
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=FAVORITA
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# Databricks
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_token

# MLflow
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_NAME=/pricing/elasticity_forecasting

# Pipeline
SPARK_MASTER=local[*]
SKU_SAMPLE_SIZE=0          # 0 = all SKUs
FORECAST_HORIZON_WEEKS=12
ELASTICITY_MIN_OBS=52      # Minimum weeks of history per SKU
